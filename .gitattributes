# 统一换行符配置

# 文本文件使用LF换行符
* text=auto eol=lf

# 明确指定常见文本文件类型
*.md text eol=lf
*.mdx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.css text eol=lf
*.html text eol=lf

# 二进制文件保持原样
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.pdf binary
*.zip binary
*.jar binary

# 可执行文件
*.sh text eol=lf
